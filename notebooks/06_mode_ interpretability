h tf.GradientTape() as tape:\n","        conv_outputs, preds = grad_model(img_array, training=False)\n","        if pred_index is None:\n","            pred_index = tf.argmax(preds[0])\n","        class_channel = preds[:, pred_index]\n","\n","    grads = tape.gradient(class_channel, conv_outputs)\n","    pooled_grads = tf.reduce_mean(grads, axis=(0, 1, 2))\n","\n","    conv_outputs = conv_outputs[0]\n","    heatmap = tf.reduce_sum(conv_outputs * pooled_grads, axis=-1)\n","    heatmap = tf.maximum(heatmap, 0)\n","\n","    max_val = tf.reduce_max(heatmap)\n","    if max_val > 0:\n","        heatmap = heatmap / max_val\n","\n","    return tf.cast(heatmap, tf.float32).numpy()"],"metadata":{"id":"xyNhAigywS4i","executionInfo":{"status":"ok","timestamp":1774809078057,"user_tz":-120,"elapsed":1,"user":{"displayName":"Teresa Tran","userId":"15744241198352490084"}}},"execution_count":10,"outputs":[]},{"cell_type":"markdown","source":["## Overlay av heatmap på originalbildet\n","\n","For å gjøre resultatet lettere å tolke visualiserer vi heatmapet både alene og som et overlay oppå originalbildet."],"metadata":{"id":"yWEgzSOg1Q9Y"}},{"cell_type":"code","source":["def overlay_heatmap_on_image(original_img_array, heatmap, alpha=0.4):\n","    heatmap = np.array(heatmap, dtype=np.float32)\n","    heatmap = np.nan_to_num(heatmap, nan=0.0, posinf=1.0, neginf=0.0)\n","    heatmap = np.clip(heatmap, 0, 1)\n","\n","    heatmap_resized = cv2.resize(\n","        heatmap,\n","        (original_img_array.shape[1], original_img_array.shape[0]),\n","        interpolation=cv2.INTER_LINEAR\n","    )\n","\n","    heatmap_uint8 = np.uint8(255 * heatmap_resized)\n","    heatmap_color = cv2.applyColorMap(heatmap_uint8, cv2.COLORMAP_JET)\n","    heatmap_color = cv2.cvtColor(heatmap_color, cv2.COLOR_BGR2RGB)\n","\n","    superimposed = heatmap_color * alpha + original_img_array.astype(np.float32)\n","    superimposed = np.clip(superimposed, 0, 255).astype(\"uint8\")\n","\n","    return heatmap_color, superimposed"],"metadata":{"id":"bwJpU5VEwUim","executionInfo":{"status":"ok","timestamp":1774809078057,"user_tz":-120,"elapsed":0,"user":{"displayName":"Teresa Tran","userId":"15744241198352490084"}}},"execution_count":11,"outputs":[]},{"cell_type":"code","source":["def show_gradcam_for_row(row_idx, target_label=None):\n","    row = valid_df.iloc[row_idx]\n","    img_path = row[\"image_path\"]\n","\n","    _, original_img_array_batch, processed_img_array = load_and_preprocess_image(img_path)\n","    original_img_array = original_img_array_batch[0].astype(\"uint8\")\n","\n","    preds = model.predict(processed_img_array, verbose=0)[0]\n","\n","    if target_label is None:\n","        pred_index = int(np.argmax(preds))\n","        label_name = LABELS[pred_index]\n","    else:\n","        pred_index = LABELS.index(target_label)\n","        label_name = target_label\n","\n","    heatmap = make_gradcam_heatmap(\n","        processed_img_array,\n","        model,\n","        LAST_CONV_LAYER_NAME,\n","        pred_index=pred_index\n","    )\n","\n","    _, superimposed = overlay_heatmap_on_image(original_img_array, heatmap)\n","\n","    plt.figure(figsize=(15, 5))\n","\n","    plt.subplot(1, 3, 1)\n","    plt.imshow(original_img_array)\n","    plt.axis(\"off\")\n","    plt.title(\"Original image\")\n","\n","    plt.subplot(1, 3, 2)\n","    plt.imshow(heatmap, cmap=\"jet\")\n","    plt.axis(\"off\")\n","    plt.title(f\"Grad-CAM\\n{label_name}\")\n","\n","    plt.subplot(1, 3, 3)\n","    plt.imshow(superimposed)\n","    plt.axis(\"off\")\n","    plt.title(f\"Overlay\\np={preds[pred_index]:.4f}\")\n","\n","    plt.tight_layout()\n","    plt.show()\n","\n","    return {\n","        \"row_idx\": row_idx,\n","        \"label\": label_name,\n","        \"probability\": float(preds[pred_index]),\n","        \"image_path\": img_path\n","    }"],"metadata":{"id":"Rpsvm12VwjYr","executionInfo":{"status":"ok","timestamp":1774809119842,"user_tz":-120,"elapsed":0,"user":{"displayName":"Teresa Tran","userId":"15744241198352490084"}}},"execution_count":19,"outputs":[]},{"cell_type":"markdown","source":["## Eksempel 1: ett bilde fra valideringssettet\n","\n","Vi starter med ett konkret bilde fra valideringssettet for å inspisere modellens prediksjoner og Grad-CAM-visualisering."],"metadata":{"id":"Hek2EEyM1Vrl"}},{"cell_type":"code","source":["row_idx = 0\n","row = valid_df.iloc[row_idx]\n","\n","img_path = row[\"image_path\"]\n","\n","print(\"Image path:\", img_path)\n","print(\"Exists:\", Path(img_path).exists())\n","\n","pil_img, original_img_array_batch, processed_img_array = load_and_preprocess_image(img_path)\n","original_img_array = original_img_array_batch[0].astype(\"uint8\")\n","\n","plt.figure(figsize=(5, 5))\n","plt.imshow(original_img_array)\n","plt.axis(\"off\")\n","plt.title(\"Original image\")\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":478},"id":"0DWDlH97wWaI","executionInfo":{"status":"ok","timestamp":1774809078255,"user_tz":-120,"elapsed":197,"user":{"displayName":"Teresa Tran","userId":"15744241198352490084"}},"outputId":"cac7dc1b-9007-475e-efe5-12807e9f2959"},"execution_count":12,"outputs":[{"output_type":"stream","name":"stdout","text":["Image path: /kaggle/input/chexpert/valid/patient64541/study1/view1_frontal.jpg\n","Exists: True\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 500x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["## Modellprediksjoner for bildet\n","\n","Før vi lager Grad-CAM, ser vi på hvilke sannsynligheter modellen gir til de ulike labelene."],"metadata":{"id":"3I6AOYAo1c2V"}},{"cell_type":"code","source":["preds = model.predict(processed_img_array, verbose=0)[0]\n","\n","pred_df = pd.DataFrame({\n","    \"label\": LABELS,\n","    \"probability\": preds\n","}).sort_values(\"probability\", ascending=False)\n","\n","pred_df"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":206},"id":"XT